---
import Default from '@astrojs/starlight/components/Head.astro';

const { starlightRoute } = Astro.locals;
const { entry } = starlightRoute;

if (!Astro.site) throw new Error('The Astro site URL is required to build page metadata');

const siteUrl = Astro.site.origin;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const pageTitle = entry.data.title
  ? `${entry.data.title} | ProductOS`
  : 'ProductOS';
const pageDescription =
  entry.data.description ??
  'ProductOS — a product operating system: anchors, Job Specs, guides, templates, and agent-executable skills.';

// Build canonical URL for this page
const rawSlug = entry.id.replace(/\.(md|mdx)$/, '').replace(/\/index$/, '');
const slug = rawSlug || 'index';
const pageUrl = `${siteUrl}${base}/${rawSlug ? rawSlug + '/' : ''}`;

// OG image: use customSocialImage frontmatter if set, otherwise fall back to generated card
const customSocialImage: string | undefined = (entry.data as Record<string, unknown>).customSocialImage as string | undefined;
const ogImage = customSocialImage
  ? (customSocialImage.startsWith('http') ? customSocialImage : `${siteUrl}${base}/${customSocialImage.replace(/^\//, '')}`)
  : `${siteUrl}${base}/og/${slug}.png`;
---

<Default><slot /></Default>

<!-- OG image — Starlight does not emit this -->
<meta property="og:image" content={ogImage} />

<!-- Supplement / override per-page title with formatted version -->
<meta property="og:title" content={pageTitle} />
<meta property="og:url" content={pageUrl} />

<!-- Twitter Card (Starlight only sets twitter:card, not image/title/description) -->
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={pageDescription} />
<meta name="twitter:image" content={ogImage} />

<!-- Click-to-expand lightbox for content images -->
<script is:inline>
  (function () {
    function close(box) {
      box.classList.remove('open');
      setTimeout(function () { box.remove(); }, 150);
    }
    document.addEventListener('click', function (e) {
      var t = e.target;
      if (t && t.tagName === 'IMG' && t.closest && t.closest('.sl-markdown-content') && !t.closest('.pos-wordmark')) {
        if (document.querySelector('.pos-lightbox')) return;
        var box = document.createElement('div');
        box.className = 'pos-lightbox';
        var full = document.createElement('img');
        full.src = t.currentSrc || t.src;
        full.alt = t.alt || '';
        box.appendChild(full);
        box.addEventListener('click', function () { close(box); });
        document.body.appendChild(box);
        requestAnimationFrame(function () { box.classList.add('open'); });
      }
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        var box = document.querySelector('.pos-lightbox');
        if (box) close(box);
      }
    });
  })();
</script>
